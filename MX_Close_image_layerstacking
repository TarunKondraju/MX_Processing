## BIRSK model

import cv2
import numpy as np
import rasterio
from rasterio.transform import from_origin
from sklearn.metrics import mean_squared_error
import matplotlib.pyplot as plt

# Correct BRISK with appropriate parameters
def brisk_keypoints_descriptors(img, thresh=30, octaves=3, pattern_scale=1.0):
    brisk = cv2.BRISK_create(thresh, octaves, pattern_scale)
    keypoints, descriptors = brisk.detectAndCompute(img, None)
    return keypoints, descriptors

# Function to match descriptors using adjustable max_matches
def match_features(des1, des2, max_matches=500):
    bf = cv2.BFMatcher(cv2.NORM_L2, crossCheck=True)
    matches = bf.match(des1, des2)
    matches = sorted(matches, key=lambda x: x.distance)
    # Limit the number of matches to max_matches
    return matches[:max_matches]

# Function to apply transformation and get inlier percentage
def apply_transformation(kp1, kp2, matches, transformation_type, img, ref_img):
    src_pts = np.float32([kp1[m.queryIdx].pt for m in matches]).reshape(-1, 1, 2)
    dst_pts = np.float32([kp2[m.trainIdx].pt for m in matches]).reshape(-1, 1, 2)
    
    if transformation_type == 'homography':
        matrix, mask = cv2.findHomography(src_pts, dst_pts, cv2.RANSAC, 5.0)
        aligned_img = cv2.warpPerspective(img, matrix, (ref_img.shape[1], ref_img.shape[0]))
    elif transformation_type == 'affine':
        matrix, mask = cv2.estimateAffinePartial2D(src_pts, dst_pts, method=cv2.RANSAC)
        aligned_img = cv2.warpAffine(img, matrix, (ref_img.shape[1], ref_img.shape[0]))
    elif transformation_type == 'projective':
        matrix, mask = cv2.estimateAffinePartial2D(src_pts, dst_pts, method=cv2.RANSAC)
        aligned_img = cv2.warpAffine(img, matrix, (ref_img.shape[1], ref_img.shape[0]))
    elif transformation_type == 'similarity':
        matrix, mask = cv2.estimateAffine2D(src_pts, dst_pts, method=cv2.RANSAC)
        aligned_img = cv2.warpAffine(img, matrix, (ref_img.shape[1], ref_img.shape[0]))
    else:
        raise ValueError("Unknown transformation type")
    
    inliers = np.sum(mask)
    total_matches = len(matches)
    inlier_percentage = (inliers / total_matches) * 100 if total_matches > 0 else 0
    
    print(f"Total matches: {total_matches}, Inliers: {inliers}, Inlier percentage: {inlier_percentage:.2f}%")
    
    return aligned_img, inlier_percentage

# Function to display keypoints on an image
def draw_keypoints(img, keypoints, title):
    img_with_keypoints = cv2.drawKeypoints(img, keypoints, None, flags=cv2.DRAW_MATCHES_FLAGS_DRAW_RICH_KEYPOINTS)
    plt.imshow(img_with_keypoints, cmap='gray')
    plt.title(title)
    plt.axis('off')
    plt.show()

# Function to display matches between two images
def draw_matches(img1, kp1, img2, kp2, matches, title):
    img_matches = cv2.drawMatches(img1, kp1, img2, kp2, matches[:50], None, flags=cv2.DrawMatchesFlags_NOT_DRAW_SINGLE_POINTS)
    plt.imshow(img_matches, cmap='gray')
    plt.title(title)
    plt.axis('off')
    plt.show()

# Function to calculate RMSE
def calculate_rmse(img1, img2):
    error = mean_squared_error(img1, img2, squared=False)
    return error

# Function to save aligned images as stacked TIFF
def save_as_rasterio_tiff(blue, green, red, red_edge, nir, output_path):
    height, width = blue.shape
    transform = from_origin(0, 0, 1, 1)

    with rasterio.open(
        output_path, 'w',
        driver='GTiff',
        height=height,
        width=width,
        count=5,
        dtype=blue.dtype,
        crs='+proj=latlong',
        transform=transform
    ) as dst:
        dst.write(blue, 1)
        dst.write(green, 2)
        dst.write(red, 3)
        dst.write(red_edge, 4)
        dst.write(nir, 5)

