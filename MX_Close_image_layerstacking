import cv2
import numpy as np
import rasterio
from rasterio.transform import from_origin
from sklearn.metrics import mean_squared_error
import matplotlib.pyplot as plt

# Harris Corner Detection for keypoints
def harris_keypoints(img, block_size=2, ksize=3, k=0.04):
    # Harris corner detection
    gray = np.float32(img)
    dst = cv2.cornerHarris(gray, block_size, ksize, k)

    # Normalizing and extracting keypoints
    dst = cv2.dilate(dst, None)
    keypoints = np.argwhere(dst > 0.01 * dst.max())  # Threshold to get strong corners

    # Convert corner points to OpenCV Keypoint objects
    keypoints = [cv2.KeyPoint(float(p[1]), float(p[0]), 1) for p in keypoints]
    
    return keypoints

# Function to extract descriptors using ORB
def orb_descriptors(img, keypoints):
    # Create ORB object to compute descriptors for Harris keypoints
    orb = cv2.ORB_create()
    keypoints, descriptors = orb.compute(img, keypoints)
    return keypoints, descriptors

# Function to match descriptors using adjustable max_matches
def match_features(des1, des2, max_matches=500):
    bf = cv2.BFMatcher(cv2.NORM_HAMMING, crossCheck=True)  # Use NORM_HAMMING for ORB descriptors
    matches = bf.match(des1, des2)
    matches = sorted(matches, key=lambda x: x.distance)
    # Limit the number of matches to max_matches
    return matches[:max_matches]

# Function to apply transformation and get inlier percentage
def apply_transformation(kp1, kp2, matches, transformation_type, img, ref_img):
    src_pts = np.float32([kp1[m.queryIdx].pt for m in matches]).reshape(-1, 1, 2)
    dst_pts = np.float32([kp2[m.trainIdx].pt for m in matches]).reshape(-1, 1, 2)
    
    if transformation_type == 'homography':
        matrix, mask = cv2.findHomography(src_pts, dst_pts, cv2.RANSAC, 5.0)
        aligned_img = cv2.warpPerspective(img, matrix, (ref_img.shape[1], ref_img.shape[0]))
    elif transformation_type == 'affine':
        matrix, mask = cv2.estimateAffinePartial2D(src_pts, dst_pts, method=cv2.RANSAC)
        aligned_img = cv2.warpAffine(img, matrix, (ref_img.shape[1], ref_img.shape[0]))
    elif transformation_type == 'projective':
        matrix, mask = cv2.estimateAffinePartial2D(src_pts, dst_pts, method=cv2.RANSAC)
        aligned_img = cv2.warpAffine(img, matrix, (ref_img.shape[1], ref_img.shape[0]))
    elif transformation_type == 'similarity':
        matrix, mask = cv2.estimateAffine2D(src_pts, dst_pts, method=cv2.RANSAC)
        aligned_img = cv2.warpAffine(img, matrix, (ref_img.shape[1], ref_img.shape[0]))
    else:
        raise ValueError("Unknown transformation type")
    
    inliers = np.sum(mask)
    total_matches = len(matches)
    inlier_percentage = (inliers / total_matches) * 100 if total_matches > 0 else 0
    
    print(f"Total matches: {total_matches}, Inliers: {inliers}, Inlier percentage: {inlier_percentage:.2f}%")
    
    return aligned_img, inlier_percentage

# Function to display keypoints on an image
def draw_keypoints(img, keypoints, title):
    img_with_keypoints = cv2.drawKeypoints(img, keypoints, None, flags=cv2.DRAW_MATCHES_FLAGS_DRAW_RICH_KEYPOINTS)
    plt.imshow(img_with_keypoints, cmap='gray')
    plt.title(title)
    plt.axis('off')
    plt.show()

# Function to display matches between two images
def draw_matches(img1, kp1, img2, kp2, matches, title):
    img_matches = cv2.drawMatches(img1, kp1, img2, kp2, matches[:50], None, flags=cv2.DrawMatchesFlags_NOT_DRAW_SINGLE_POINTS)
    plt.imshow(img_matches, cmap='gray')
    plt.title(title)
    plt.axis('off')
    plt.show()

# Function to calculate RMSE
def calculate_rmse(img1, img2):
    error = mean_squared_error(img1, img2, squared=False)
    return error

# Function to save aligned images as stacked TIFF
def save_as_rasterio_tiff(blue, green, red, red_edge, nir, output_path):
    height, width = blue.shape
    transform = from_origin(0, 0, 1, 1)

    with rasterio.open(
        output_path, 'w',
        driver='GTiff',
        height=height,
        width=width,
        count=5,
        dtype=blue.dtype,
        crs='+proj=latlong',
        transform=transform
    ) as dst:
        dst.write(blue, 1)
        dst.write(green, 2)
        dst.write(red, 3)
        dst.write(red_edge, 4)
        dst.write(nir, 5)

# Main logic with adjustable max_matches
def process_bands(band_images, ref_img, image_names, max_matches=1500):
    aligned_images = {'homography': [], 'affine': [], 'projective': [], 'similarity': []}
    inlier_percentages = {'homography': [], 'affine': [], 'projective': [], 'similarity': []}

    for i, img in enumerate(band_images):
        print(f"\nProcessing {image_names[i]} band...")

        # Detect keypoints using Harris Corner Detection
        kp1 = harris_keypoints(img)
        kp2 = harris_keypoints(ref_img)

        # Extract descriptors using ORB for the detected Harris keypoints
        kp1, des1 = orb_descriptors(img, kp1)
        kp2, des2 = orb_descriptors(ref_img, kp2)

        # Display the keypoints
        draw_keypoints(img, kp1, f'{image_names[i]} Band Keypoints (Harris)')
        draw_keypoints(ref_img, kp2, 'Reference (RedEdge) Keypoints (Harris)')

        # Match features
        matches = match_features(des1, des2, max_matches)
        print(f"Total matches found between {image_names[i]} band and RedEdge: {len(matches)}")

        # Draw and display matches
        draw_matches(img, kp1, ref_img, kp2, matches, f'Matched Features - {image_names[i]} Band (Harris + ORB)')

        # Apply transformations and calculate RMSE and inlier percentage
        for transformation_type in ['homography', 'affine', 'projective', 'similarity']:
            aligned_img, inlier_percentage = apply_transformation(kp1, kp2, matches, transformation_type, img, ref_img)
            aligned_images[transformation_type].append(aligned_img)
            inlier_percentages[transformation_type].append(inlier_percentage)

            # Compute and print RMSE
            rmse = calculate_rmse(aligned_img, ref_img)
            print(f"RMSE after {transformation_type.capitalize()} Transformation: {rmse:.4f}")

            # Display the transformed image alongside the reference for visual inspection
            plt.figure(figsize=(10, 5))
            plt.subplot(1, 2, 1)
            plt.imshow(ref_img, cmap='gray')
            plt.title("Reference (RedEdge)")

            plt.subplot(1, 2, 2)
            plt.imshow(aligned_img, cmap='gray')
            plt.title(f'Aligned {image_names[i]} Band ({transformation_type.capitalize()})')

            plt.show()

    return aligned_images, inlier_percentages

