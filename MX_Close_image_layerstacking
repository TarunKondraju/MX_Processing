import cv2
import rasterio
import numpy as np
from matplotlib import pyplot as plt
import tifffile as tiff
from PIL import Image
from skimage.metrics import structural_similarity as ssim
from scipy.stats import entropy

# Function to register band using feature-based methods
def register_band(ref_image, band_image, method):
    if method == 'SIFT':
        detector = cv2.SIFT_create()
    elif method == 'ORB':
        detector = cv2.ORB_create()
    elif method == 'BRISK':
        detector = cv2.BRISK_create()
    elif method == 'KAZE':
        detector = cv2.KAZE_create()
    elif method == 'MSER':
        # MSER detects regions; we need another method (like ORB) to compute descriptors
        mser = cv2.MSER_create()
        kp1 = mser.detect(ref_image)
        kp2 = mser.detect(band_image)
        # Use ORB to compute descriptors
        orb = cv2.ORB_create()
        kp1, des1 = orb.compute(ref_image, kp1)
        kp2, des2 = orb.compute(band_image, kp2)
    else:
        raise ValueError(f"Method {method} is not supported")

    if method != 'MSER':  # MSER uses ORB for descriptors, others are handled here
        kp1, des1 = detector.detectAndCompute(ref_image, None)
        kp2, des2 = detector.detectAndCompute(band_image, None)

    # Use a matcher based on method
    if method in ['SIFT', 'KAZE']:
        index_params = dict(algorithm=0, trees=5)
        search_params = dict(checks=50)
        matcher = cv2.FlannBasedMatcher(index_params, search_params)
    else:
        matcher = cv2.BFMatcher(cv2.NORM_HAMMING, crossCheck=True)

    matches = matcher.match(des1, des2)
    matches = sorted(matches, key=lambda x: x.distance)

    src_pts = np.float32([kp1[m.queryIdx].pt for m in matches]).reshape(-1, 1, 2)
    dst_pts = np.float32([kp2[m.trainIdx].pt for m in matches]).reshape(-1, 1, 2)

    matrix, mask = cv2.findHomography(dst_pts, src_pts, cv2.RANSAC, 5.0)
    height, width = ref_image.shape
    aligned_image = cv2.warpPerspective(band_image, matrix, (width, height))

    return aligned_image


# Function to save multi-channel image as a single TIFF file
def save_multichannel_tiff(image_array, output_path):
    """
    Save a multi-channel image (e.g., 5-band image) as a single TIFF file.
    
    Parameters:
    - image_array: A 3D NumPy array (height, width, channels) representing the stacked image.
    - output_path: Path where the output TIFF image will be saved.
    """
    # Ensure the image array is a NumPy array and has multiple channels
    if len(image_array.shape) != 3:
        raise ValueError("Image array must be 3-dimensional (height, width, channels).")
    
    # Save the multi-channel image as a single TIFF file
    tiff.imwrite(output_path, image_array, photometric='minisblack')  # photometric='rgb' for color images
    #cv2.imwrite(output_tiff_path, stacked_image_uint8)
    
    print(f"Multi-channel image saved as {output_path}")


# Error matrix calculation: MSE, SSIM, and Entropy between the registered and reference image
def calculate_error_metrics(ref_image, aligned_image):
    mse_value = np.mean((ref_image - aligned_image) ** 2)
    ssim_value, _ = ssim(ref_image, aligned_image, full=True)
    entropy_value = entropy(ref_image.flatten(), aligned_image.flatten())
    return mse_value, ssim_value, entropy_value

# ECC (Enhanced Correlation Coefficient) method
def ecc_register(ref_image, band_image):
    warp_matrix = np.eye(3, 3, dtype=np.float32)
    criteria = (cv2.TERM_CRITERIA_EPS | cv2.TERM_CRITERIA_COUNT, 5000, 1e-10)
    cc, warp_matrix = cv2.findTransformECC(ref_image, band_image, warp_matrix, cv2.MOTION_HOMOGRAPHY, criteria)
    height, width = ref_image.shape
    aligned_image = cv2.warpPerspective(band_image, warp_matrix, (width, height), flags=cv2.INTER_LINEAR + cv2.WARP_INVERSE_MAP)
    return aligned_image

# CFOB (Correlation Feature-Based Registration) method using phase correlation
def cfob_register(ref_image, band_image):
    # Use Fourier Transform for phase correlation
    # Calculate the phase correlation between the reference and band image
    shift = cv2.phaseCorrelate(np.float32(ref_image), np.float32(band_image))
    
    # Shift the band image according to the correlation shift
    matrix = np.float32([[1, 0, shift[0][0]], [0, 1, shift[0][1]]])
    height, width = ref_image.shape
    aligned_image = cv2.warpAffine(band_image, matrix, (width, height))
    return aligned_image

# DSIM (Dissimilarity-Based Image Matching) method using Mutual Information
def dsim_register(ref_image, band_image):
    # Compute the Mutual Information (MI) between the reference and band image
    hist_2d, _, _ = np.histogram2d(ref_image.ravel(), band_image.ravel(), bins=20)
    mi = mutual_information(hist_2d)
    
    # Warp based on MI (placeholder: using ECC for alignment)
    return ecc_register(ref_image, band_image)

# Mutual information calculation
def mutual_information(hist_2d):
    pxy = hist_2d / float(np.sum(hist_2d))  # Joint probability distribution
    px = np.sum(pxy, axis=1)  # Marginal probability for x
    py = np.sum(pxy, axis=0)  # Marginal probability for y
    pxy_nonzero = pxy[np.nonzero(pxy)]  # Non-zero joint probabilities
    px_py_nonzero = np.outer(px, py)[np.nonzero(pxy)]  # Non-zero product of marginals
    mi = np.sum(pxy_nonzero * np.log(pxy_nonzero / px_py_nonzero))  # Mutual Information formula
    return mi

