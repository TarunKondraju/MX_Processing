# SWIFT model
import cv2
import numpy as np
import matplotlib.pyplot as plt
import rasterio
from rasterio.transform import from_origin

# Function to detect keypoints and descriptors using SIFT
def sift_keypoints_descriptors(img):
    sift = cv2.SIFT_create()
    keypoints, descriptors = sift.detectAndCompute(img, None)
    return keypoints, descriptors

# Function to match descriptors between two images
def match_features(des1, des2):
    bf = cv2.BFMatcher(cv2.NORM_L2, crossCheck=True)
    matches = bf.match(des1, des2)
    matches = sorted(matches, key=lambda x: x.distance)
    return matches

# Function to display keypoints on an image
def draw_keypoints(img, keypoints, title):
    img_with_keypoints = cv2.drawKeypoints(img, keypoints, None, flags=cv2.DRAW_MATCHES_FLAGS_DRAW_RICH_KEYPOINTS)
    plt.imshow(img_with_keypoints, cmap='gray')
    plt.title(title)
    plt.axis('off')
    plt.show()

# Function to display matches between two images
def draw_matches(img1, kp1, img2, kp2, matches, title):
    img_matches = cv2.drawMatches(img1, kp1, img2, kp2, matches[:50], None, flags=cv2.DrawMatchesFlags_NOT_DRAW_SINGLE_POINTS)
    plt.imshow(img_matches, cmap='gray')
    plt.title(title)
    plt.axis('off')
    plt.show()

# Function to apply transformation using keypoints and matches
def apply_transformation(kp1, kp2, matches, transformation_type, img, ref_img):
    # Extract matching keypoints
    src_pts = np.float32([kp1[m.queryIdx].pt for m in matches]).reshape(-1, 1, 2)
    dst_pts = np.float32([kp2[m.trainIdx].pt for m in matches]).reshape(-1, 1, 2)
    
    # Choose transformation
    if transformation_type == 'homography':
        matrix, mask = cv2.findHomography(src_pts, dst_pts, cv2.RANSAC, 5.0)
        aligned_img = cv2.warpPerspective(img, matrix, (ref_img.shape[1], ref_img.shape[0]))
    elif transformation_type == 'affine':
        matrix, mask = cv2.estimateAffinePartial2D(src_pts, dst_pts)
        aligned_img = cv2.warpAffine(img, matrix, (ref_img.shape[1], ref_img.shape[0]))
    elif transformation_type == 'projective':
        matrix, mask = cv2.estimateAffinePartial2D(src_pts, dst_pts, method=cv2.RANSAC)
        aligned_img = cv2.warpAffine(img, matrix, (ref_img.shape[1], ref_img.shape[0]))
    elif transformation_type == 'similarity':
        matrix, mask = cv2.estimateAffine2D(src_pts, dst_pts)
        aligned_img = cv2.warpAffine(img, matrix, (ref_img.shape[1], ref_img.shape[0]))
    else:
        raise ValueError("Unknown transformation type")
    
    return aligned_img

# Function to compute RMSE between two images
def compute_rmse(img1, img2):
    return np.sqrt(np.mean((img1.astype(np.float32) - img2.astype(np.float32)) ** 2))

