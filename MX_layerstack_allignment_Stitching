            output_path = os.path.join(output_folder, filename)

            # Read radiance image
            image = cv2.imread(file_path, cv2.IMREAD_UNCHANGED).astype(np.float32)

            # Convert to reflectance
            reflectance_image = image * reflectance_factors[band]

            # Save the reflectance image as a 32-bit float TIFF
            cv2.imwrite(output_path, reflectance_image.astype(np.float32))

            print(f"Saved reflectance image for {band}: {output_path}")
def main():
    panel_folder = r"C:\\Tarun\\CIFA_ponds\\0000SET\\Cifa_40\\data\\panel"
    land_folder = r"C:\\Tarun\\CIFA_ponds\\0000SET\\Cifa_40\\data\\images"
    radiance_panel_folder = r"C:\\Tarun\\CIFA_ponds\\0000SET\\Cifa_40\\data\\RadiancePanel1"
    radiance_land_folder = r"C:\\Tarun\\CIFA_ponds\\0000SET\\Cifa_40\\data\\RadianceLand1"
    reflectance_output_folder = r"C:\\Tarun\\CIFA_ponds\\0000SET\\Cifa_40\\data\\ReflectanceOutput"
    bands = ["Blue", "Green", "Red", "Red edge", "NIR"]

    # Step 1: Convert panel and land images to radiance
    process_images_to_radiance(panel_folder, radiance_panel_folder)
    process_images_to_radiance(land_folder, radiance_land_folder)

    # Step 2: Interactively calculate reflectance factors
    reflectance_factors = {}
    for band, filename in zip(bands, sorted(os.listdir(radiance_panel_folder))):
        image_path = os.path.join(radiance_panel_folder, filename)
        bounding_box = interactive_box_drawing(image_path)
        if bounding_box:
            image = cv2.imread(image_path, cv2.IMREAD_UNCHANGED)
