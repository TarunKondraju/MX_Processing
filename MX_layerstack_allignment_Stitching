# Process each image
for image_name, metadata in metadata_dict.items():
    image_path = Path(input_folder) / image_name
    output_image_path = Path(output_folder) / f"georeferenced_{image_name}"

    # Open image using GDAL
    ds = gdal.Open(str(image_path))
    if ds is None:
        print(f"Error: Unable to open {image_path}")
        continue

    # Spatial reference system (WGS 84)
    srs = osr.SpatialReference()
    srs.ImportFromEPSG(4326)

    # Convert pixel size from meters to degrees
    pixel_size_lat, pixel_size_long = convert_pixel_size_to_degrees(pixel_size_meters, metadata["latitude"])

    center_x = metadata["longitude"] - (pixel_size_long * ds.RasterXSize / 2)
    center_y = metadata["latitude"] + (pixel_size_lat * ds.RasterYSize / 2)

    new_geotransform = (
        center_x,        # Top-left corner longitude
        pixel_size_long,   # Pixel size in longitude direction
        0,                 # No rotation (row rotation)
        center_y,        # Top-left corner latitude
        0,                 # No rotation (column rotation)
        -pixel_size_lat    # Negative for north-down
    )

    # Create the output dataset
    driver = gdal.GetDriverByName("GTiff")
    out_ds = driver.Create(
        str(output_image_path),
        ds.RasterXSize,
        ds.RasterYSize,
        ds.RasterCount,
        ds.GetRasterBand(1).DataType,
    )
    if out_ds is None:
        print(f"Error: Unable to create output dataset for {output_image_path}")
        ds = None
        continue

    # Apply geo-transform and projection
    out_ds.SetGeoTransform(new_geotransform)
    out_ds.SetProjection(srs.ExportToWkt())

    # Copy all raster bands
    for i in range(1, ds.RasterCount + 1):
        in_band = ds.GetRasterBand(i)
        out_band = out_ds.GetRasterBand(i)
        out_band.WriteArray(in_band.ReadAsArray())

    # Close datasets
    out_ds = None
    ds = None

    print(f"Georeferenced image saved to: {output_image_path}")

# Final message
print("Processing complete!")


