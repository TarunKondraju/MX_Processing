    pixel_size_lat, pixel_size_long = convert_pixel_size_to_degrees(pixel_size_meters, metadata["latitude"])

    # Calculate georeferencing point based on the center of the rotated image
    center_x = metadata["longitude"] - (pixel_size_long * rotated_image.shape[1] / 2)
    center_y = metadata["latitude"] + (pixel_size_lat * rotated_image.shape[0] / 2)
    
    new_geotransform = (
