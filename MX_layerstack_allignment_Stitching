# Function to convert pixel size to degrees
def convert_pixel_size_to_degrees(pixel_size_meters, latitude):
    """Converts pixel size in meters to degrees based on latitude."""
    pixel_size_lat = pixel_size_meters / 111320  # Degrees latitude per meter
    pixel_size_long = pixel_size_meters / (111320 * math.cos(math.radians(latitude)))  # Degrees longitude per meter
    return pixel_size_lat, pixel_size_long


# Function to rotate an image without cropping
def rotate_image_without_clipping(image, angle):
    """Rotates an image without cropping or clipping."""
    (h, w) = image.shape[:2]
    center = (w // 2, h // 2)
    rotation_matrix = cv2.getRotationMatrix2D(center, -angle, 1.0)

    # Calculate new bounding dimensions
    abs_cos = abs(rotation_matrix[0, 0])
    abs_sin = abs(rotation_matrix[0, 1])
    new_w = int(h * abs_sin + w * abs_cos)
    new_h = int(h * abs_cos + w * abs_sin)

    # Adjust the rotation matrix to account for the new bounding dimensions
    rotation_matrix[0, 2] += (new_w / 2) - center[0]
    rotation_matrix[1, 2] += (new_h / 2) - center[1]

    # Perform the actual rotation
    rotated_image = cv2.warpAffine(image, rotation_matrix, (new_w, new_h), flags=cv2.INTER_LINEAR, borderMode=cv2.BORDER_CONSTANT)
    return rotated_image


# Function to process the layerstacked image
def process_layerstacked_image(input_path, output_path, metadata, pixel_size_meters):
    """Processes a layerstacked image by applying georeferencing and rotation."""
    # Open the layerstacked image
    ds = gdal.Open(input_path)
    if ds is None:
        print(f"Error: Unable to open {input_path}")
        return

    # Read the image data (all bands)
    bands = [ds.GetRasterBand(i + 1).ReadAsArray() for i in range(ds.RasterCount)]
    stacked_image = np.stack(bands, axis=-1)

    # Rotate the image
    rotated_image = rotate_image_without_clipping(stacked_image, metadata["rotation"])

    # Convert pixel size from meters to degrees
    pixel_size_lat, pixel_size_long = convert_pixel_size_to_degrees(pixel_size_meters, metadata["latitude"])

    # Calculate georeferencing based on the rotated image size
    center_x = metadata["longitude"] - (pixel_size_long * rotated_image.shape[1] / 2)
    center_y = metadata["latitude"] + (pixel_size_lat * rotated_image.shape[0] / 2)

    new_geotransform = (
        center_x,           # Top-left longitude
        pixel_size_long,    # Pixel size in longitude
        0,                  # No rotation/skew in X direction
        center_y,           # Top-left latitude
        0,                  # No rotation/skew in Y direction
        -pixel_size_lat     # Pixel size in latitude (negative for North-to-South)
    )

    # Spatial reference system (WGS 84)
    srs = osr.SpatialReference()
    srs.ImportFromEPSG(4326)

    # Create the output dataset
    driver = gdal.GetDriverByName("GTiff")
    out_ds = driver.Create(
        output_path,
        rotated_image.shape[1],
        rotated_image.shape[0],
        ds.RasterCount,
        gdal.GDT_Float32,
    )
    if out_ds is None:
        print(f"Error: Unable to create output dataset for {output_path}")
        return

    # Apply geotransform and projection
    out_ds.SetGeoTransform(new_geotransform)
    out_ds.SetProjection(srs.ExportToWkt())

    # Write each band to the output
    for i in range(rotated_image.shape[-1]):
        out_ds.GetRasterBand(i + 1).WriteArray(rotated_image[:, :, i])

    # Close datasets
    out_ds = None
    ds = None
    print(f"Processed and saved: {output_path}")


