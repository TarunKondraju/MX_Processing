def convert_pixel_size_to_degrees(pixel_size_meters, latitude):
    """
    Converts pixel size in meters to degrees of latitude and longitude
    based on the given latitude.
    """
    pixel_size_lat = pixel_size_meters / 111320  # Degrees latitude per meter
    pixel_size_long = pixel_size_meters / (111320 * math.cos(math.radians(latitude)))  # Degrees longitude per meter
    return pixel_size_lat, pixel_size_long

def ModifiedWay(image, angle):
    """
    Rotates an image without cropping any portion.
    """
    (h, w) = image.shape[:2]
    center = (w // 2, h // 2)
    angle = -angle

    rotation_matrix = cv2.getRotationMatrix2D(center, angle, 1.0)
    abs_cos = abs(rotation_matrix[0, 0])
    abs_sin = abs(rotation_matrix[0, 1])

    new_w = int(h * abs_sin + w * abs_cos)
    new_h = int(h * abs_cos + w * abs_sin)

    rotation_matrix[0, 2] += (new_w / 2) - center[0]
    rotation_matrix[1, 2] += (new_h / 2) - center[1]

    rotated_image = cv2.warpAffine(image, rotation_matrix, (new_w, new_h), flags=cv2.INTER_LINEAR, borderMode=cv2.BORDER_CONSTANT)
    return rotated_image

def mosaic_band_ignore_padding(band_suffix, band_name, nodata_value=0):
    """
    Mosaics images of a specific band, ignoring padding values.
    """
