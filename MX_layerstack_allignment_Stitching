## reads metadata

import os
import csv
from exiftool import ExifTool

def extract_all_metadata(image_path):
    """
    Extract all metadata from an image using ExifTool.
    Args:
        image_path (str): Path to the image file.
    Returns:
        dict: Dictionary of all metadata key-value pairs.
    """
    with ExifTool() as et:
        metadata = et.get_metadata(image_path)  # Collect all available metadata
    return metadata

def save_all_metadata_to_csv(image_folder, output_csv_path):
    """
    Extract all metadata from images in a folder and save to a CSV file.
    Args:
        image_folder (str): Folder containing the images.
        output_csv_path (str): Path to save the metadata CSV file.
    """
    if not os.path.exists(os.path.dirname(output_csv_path)):
        os.makedirs(os.path.dirname(output_csv_path))

    # Collect metadata from all images
    metadata_list = []
    for filename in os.listdir(image_folder):
        if filename.lower().endswith(('.tif', '.jpg', '.png')):  # Adjust extensions as needed
            image_path = os.path.join(image_folder, filename)
            metadata = extract_all_metadata(image_path)
            metadata['SourceFile'] = filename  # Add filename for reference
            metadata_list.append(metadata)

    # Determine all unique keys (to handle missing fields in some images)
    all_keys = set()
    for metadata in metadata_list:
        all_keys.update(metadata.keys())
    
    # Write metadata to a CSV file
    with open(output_csv_path, mode='w', newline='', encoding='utf-8') as csvfile:
        writer = csv.DictWriter(csvfile, fieldnames=sorted(all_keys))  # Sort keys for consistent columns
        writer.writeheader()
        for metadata in metadata_list:
            writer.writerow(metadata)

    print(f"Metadata saved to {output_csv_path}")

