## Reads images, radiometric calibration

import os
import cv2
import numpy as np
from exiftool import ExifTool

# Panel Calibration values
panelCalibration = {
    "Blue": 0.52,
    "Green": 0.53,
    "Red": 0.53,
    "Red edge": 0.53,
    "NIR": 0.53
}

# Global variables for bounding box
drawing = False
ix, iy = -1, -1
rectangle = None

def extract_metadata(filepath):
    """Extracts required metadata using ExifTool."""
    with ExifTool() as et:
        metadata = et.get_metadata(filepath)
    return metadata

def vignette_map(meta, x_dim, y_dim):
    """Computes the vignette correction map from metadata."""
    x, y = np.meshgrid(np.arange(x_dim), np.arange(y_dim))
    x = x.T
    y = y.T

    vignetting_center_size = len(meta.get("XMP:VignettingCenter", []))
    vignetting_polynomial_2d_size = len(meta.get("XMP:VignettingPolynomial2D", []))

    if vignetting_center_size > 0:
        x_vignette = float(meta['XMP:VignettingCenter'][0])
        y_vignette = float(meta['XMP:VignettingCenter'][1])
        vignette_poly = list(map(float, meta['XMP:VignettingPolynomial']))
        vignette_poly.reverse()
        vignette_poly.append(1.0)
        r = np.hypot(x - x_vignette, y - y_vignette)
        vignette = 1.0 / np.polyval(vignette_poly, r)

    elif vignetting_polynomial_2d_size > 0:
        xv = x.T / x_dim
        yv = y.T / y_dim
        coeffs = meta['XMP:VignettingPolynomial2D']
        exponents = meta['XMP:VignettingPolynomial2DExponents']
        vignette = np.zeros_like(xv, dtype=float)
        for i, c in enumerate(coeffs):
            ex = exponents[2 * i]
            ey = exponents[2 * i + 1]
            vignette += c * xv**ex * yv**ey
        vignette = 1.0 / vignette.T
    else:
        raise ValueError("No valid vignette correction data found in metadata.")

    return vignette, x, y

def raw_image_to_radiance(meta, image_raw):
    """Converts raw DN image to radiance."""
    a1, a2, a3 = [float(val) for val in meta['XMP:RadiometricCalibration']]
    black_levels = [float(val) for val in meta['EXIF:BlackLevel'].split(' ')]
    dark_level = np.mean(black_levels)
    exposure_time = float(meta['EXIF:ExposureTime'])
    gain = float(meta['EXIF:ISOSpeed']) / 100.0

    x_dim, y_dim = image_raw.shape
    V, x, y = vignette_map(meta, x_dim, y_dim)
    R = 1.0 / (1.0 + a2 * y / exposure_time - a3 * y)
    L = V * R * (image_raw - dark_level)
    L[L < 0] = 0

    bits_per_pixel = int(meta['EXIF:BitsPerSample'])
    bit_depth_max = float(2 ** bits_per_pixel)
    radiance_image = L.astype(float) / (gain * exposure_time) * a1 / bit_depth_max

    return radiance_image

def process_images_to_radiance(folder_path, output_folder):
    """Processes images to compute radiance."""
    if not os.path.exists(output_folder):
        os.makedirs(output_folder)
    
    for filename in os.listdir(folder_path):
        if filename.endswith('.tif'):
            file_path = os.path.join(folder_path, filename)
            output_path = os.path.join(output_folder, filename)

            metadata = extract_metadata(file_path)
            raw_image = cv2.imread(file_path, cv2.IMREAD_UNCHANGED)
            radiance_image = raw_image_to_radiance(metadata, raw_image)
            cv2.imwrite(output_path, (radiance_image * 65535).astype(np.uint16))

def draw_rectangle(event, x, y, flags, param):
    """Callback function for drawing a rectangle interactively."""
    global ix, iy, drawing, rectangle

    if event == cv2.EVENT_LBUTTONDOWN:
        drawing = True
        ix, iy = x, y

    elif event == cv2.EVENT_MOUSEMOVE:
        if drawing:
            temp_image = param.copy()
            cv2.rectangle(temp_image, (ix, iy), (x, y), (0, 255, 0), 2)
            cv2.imshow("Draw a bounding box", temp_image)

    elif event == cv2.EVENT_LBUTTONUP:
        drawing = False
        rectangle = (ix, iy, x, y)
        cv2.rectangle(param, (ix, iy), (x, y), (0, 255, 0), 2)
        cv2.imshow("Draw a bounding box", param)

def interactive_box_drawing(image_path):
    """Allows the user to draw a bounding box on an image."""
    global rectangle

    image = cv2.imread(image_path, cv2.IMREAD_UNCHANGED)
    if image.dtype == np.uint16:
        image = cv2.normalize(image, None, 0, 255, cv2.NORM_MINMAX).astype(np.uint8)
    image_copy = image.copy()
    cv2.imshow("Draw a bounding box", image_copy)
    cv2.setMouseCallback("Draw a bounding box", draw_rectangle, image_copy)

    while True:
        key = cv2.waitKey(1) & 0xFF
        if key == ord('q'):
            break

    cv2.destroyAllWindows()
    return rectangle

def calculate_mean_radiance(image, bounding_box):
    """Calculate mean radiance inside the bounding box."""
    x1, y1, x2, y2 = bounding_box
    panel_region = image[y1:y2, x1:x2]
    return np.mean(panel_region)

def apply_reflectance_conversion(land_folder, reflectance_factors, output_folder, bands):
    """Convert radiance land images to reflectance and save as float TIFF."""
    if not os.path.exists(output_folder):
        os.makedirs(output_folder)

    for filename in os.listdir(land_folder):
