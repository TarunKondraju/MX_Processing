with open(csv_file, mode="r", newline="", encoding="utf-8") as csvfile:
    reader = csv.DictReader(csvfile)
    for row in reader:
        image_name = row["File:FileName"]  # Image filename
        lon = float(row["EXIF:GPSLongitude"])  # Latitude in DD
        lat = float(row["EXIF:GPSLatitude"])  # Longitude in DD
