# Function to convert pixel size to degrees
def convert_pixel_size_to_degrees(pixel_size_meters, latitude):
    """
    Converts pixel size in meters to degrees of latitude and longitude
    based on the given latitude.
    """
    pixel_size_lat = pixel_size_meters / 111320  # Degrees latitude per meter
    pixel_size_long = pixel_size_meters / (111320 * math.cos(math.radians(latitude)))  # Degrees longitude per meter
    return pixel_size_lat, pixel_size_long

# Read metadata
metadata_dict = {}
#csv_file = r"D:\\Tarun\\iari\\Amrit_Sarovar\\test\\image_metadata.csv"
csv_file = r"C:\\Tarun\\CIFA_ponds\\0000SET\\Cifa_40\\data\\metadata\\image_metadata.csv"
