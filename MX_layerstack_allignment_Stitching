    # Find all images for the given band
    images = glob.glob(os.path.join(output_folder, f"*{band_suffix}.tif"))
    if not images:
        print(f"No images found for band {band_name}")
        return
    
    # Output mosaic file path
    output_file = os.path.join(mosaic_folder, f"Mosaic_{band_name}.tif")
    
    # GDAL command for mosaicking with nodata handling
    gdal.Warp(
        output_file,
        images,
        format="GTiff",
        options=[
            "COMPRESS=LZW",  # Compression for output
            "BIGTIFF=YES",   # Support for large files
            f"UNIFIED_SRC_NODATA=YES",  # Unified nodata handling
        ],
        srcNodata=nodata_value  # Set padding value as nodata
    )
    
    print(f"Mosaic saved for band {band_name}: {output_file}")

