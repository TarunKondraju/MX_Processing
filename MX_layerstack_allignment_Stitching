        # Spatial reference system (WGS 84)
        srs = osr.SpatialReference()
        srs.ImportFromEPSG(4326)

        # Convert pixel size from meters to degrees
        pixel_size_lat, pixel_size_long = convert_pixel_size_to_degrees(pixel_size_meters, latitude)

        # Calculate georeferencing for the rotated image
        center_x = longitude - (pixel_size_long * rotated_image.shape[2] / 2)
        center_y = latitude + (pixel_size_lat * rotated_image.shape[1] / 2)

        new_geotransform = (
            center_x,           # Top-left longitude
            pixel_size_long,    # Pixel size in longitude
            0,                  # No rotation/skew in X direction
            center_y,           # Top-left latitude
            0,                  # No rotation/skew in Y direction
            -pixel_size_lat     # Pixel size in latitude (negative for North-to-South)
        )

        # Create the output dataset
        driver = gdal.GetDriverByName("GTiff")
        out_ds = driver.Create(
            output_image_path,
            rotated_image.shape[2],  # Width
            rotated_image.shape[1],  # Height
            rotated_image.shape[0],  # Number of bands
            gdal.GDT_Float32,        # Data type (matches MicaSense float32)
        )
        if out_ds is None:
            print(f"Error: Unable to create output dataset for {output_image_path}")
            continue

        # Apply geo-transform and projection
        out_ds.SetGeoTransform(new_geotransform)
        out_ds.SetProjection(srs.ExportToWkt())

        # Write the rotated bands
        for i in range(rotated_image.shape[0]):
            out_band = out_ds.GetRasterBand(i + 1)
            out_band.WriteArray(rotated_image[i, :, :])

        # Close datasets
        out_ds = None
        ds = None

        print(f"Processed and saved: {output_image_path}")

