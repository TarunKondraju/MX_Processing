## Histogram Matching

import os
import cv2
import numpy as np
from skimage import exposure

def load_image_as_float(image_path):
    """Load an image as a float32 numpy array."""
    image = cv2.imread(image_path, cv2.IMREAD_UNCHANGED).astype(np.float32)
    return image

def save_image_as_float(image, output_path):
    """Save an image as a 32-bit float TIFF."""
    cv2.imwrite(output_path, image.astype(np.float32))

def histogram_match_images(input_folder, output_folder, bands, reference_images):
    """
    Perform histogram matching for each band and save the results.
    
    Args:
        input_folder (str): Folder containing input images.
        output_folder (str): Folder to save processed images.
        bands (list): List of band names (e.g., ["Blue", "Green", "Red", "NIR", "Red edge"]).
        reference_images (dict): Dictionary containing reference images for each band.
    """
    if not os.path.exists(output_folder):
        os.makedirs(output_folder)

    for filename in os.listdir(input_folder):
        if filename.endswith('.tif'):
            band_index = int(filename.split('_')[-1].split('.')[0]) - 1
            band = bands[band_index]

            # Load input image
            image_path = os.path.join(input_folder, filename)
            image = load_image_as_float(image_path)

            # Load reference image for this band
            reference_image = reference_images[band]

            # Perform histogram matching
            matched_image = exposure.match_histograms(image, reference_image)#, multichannel=False)

            # Save the matched image
            output_path = os.path.join(output_folder, filename)
            save_image_as_float(matched_image, output_path)
            print(f"Saved histogram-matched image for {band}: {output_path}")

def prepare_reference_images(input_folder, bands):
    """
    Prepare reference images for each band by selecting one image from the folder.
    """
    reference_images = {}
    for band_index, band in enumerate(bands):
        for filename in os.listdir(input_folder):
            if filename.endswith(f"_{band_index + 1}.tif"):
                image_path = os.path.join(input_folder, filename)
                reference_images[band] = load_image_as_float(image_path)
                print(f"Selected reference image for {band}: {filename}")
                break
    return reference_images

# Example usage
input_folder = r"C:\Tarun\CIFA_ponds\0000SET\ReflectanceOutput"
output_folder = r"C:\Tarun\CIFA_ponds\0000SET\histogram1"
bands = ["Blue", "Green", "Red", "Red edge", "NIR"]

# Step 1: Prepare reference images for each band
reference_images = prepare_reference_images(input_folder, bands)

# Step 2: Perform histogram matching and save results
histogram_match_images(input_folder, output_folder, bands, reference_images)


